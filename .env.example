# ─────────────────────────────────────────────
# CRM Analytics Agent — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# LLM provider: ollama | groq
LLM_PROVIDER=ollama

# Ollama (local — no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Groq (cloud fallback — get key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override settings.yaml paths at runtime
# DATA_UPLOAD_FOLDER=data/uploads/
# DATA_CACHE_FOLDER=data/.cache/
# EXPORTS_OUTPUT_FOLDER=exports/
